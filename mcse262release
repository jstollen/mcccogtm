<script>
const D = [{"id": "f001", "theme": "1. Drive Adoption", "themeNumber": 1, "program": "Manage Consent and Preferences", "feature": "Extend Customizable Preference Pages", "pmOwner": "Chad Jordan", "description": "", "goals": "", "engOwner": "Shreyas Diwan", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "Distinct Demo of This Feature", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "Preference Page Enhancements.mp4", "vidyardLink": "", "soLink": "262 Solution Overview: Marketing Cloud Preference Page Enhancements", "pmmSlide": "", "customerValue": "", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Customers need granular control over their communication preferences \u2014 not just a simple opt-in/opt-out \u2014 but existing preference pages lack the flexibility to match brand standards or capture channel-level consent.<br><br><strong>What's New:</strong> Summer '26 introduces fully customizable preference pages in MC Next, letting you design branded, multi-channel preference centers that capture consent at the channel level (email, SMS, WhatsApp, push).<br><br><strong>How to Demo:</strong> Show the Preference Page builder in Setup \u2192 walk through adding custom fields, brand styling, and channel toggles. Then show a preview of the live preference page. Emphasize the drag-and-drop simplicity and real-time preview.<br><br><strong>Customer Value:</strong> Reduces unsubscribe rates by giving subscribers control, improves compliance posture, and strengthens brand trust with a professional, on-brand preference experience.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_consent.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"regulated": "<strong>Regulated Industries Angle:</strong> For financial services and healthcare, this is a compliance imperative. Preference pages can capture granular consent per communication channel and purpose (marketing vs. transactional), supporting TCPA, HIPAA marketing consent, and MiFID II requirements. Demo the audit trail of preference changes as evidence of consent management.", "retail-mfg": "<strong>Retail & Manufacturing Angle:</strong> Retailers can offer preference pages that let customers choose product category interests (e.g., 'Women's Apparel' vs. 'Home Goods'), communication frequency, and preferred channels \u2014 reducing email fatigue and increasing engagement. Show how a branded preference page can drive loyalty program opt-ins."}, "demoUrl": "https://drive.google.com/file/d/1JBnDPJcfM-Z20rANd6G1Q8AWPh2tDUrB/view?usp=drive_link", "soUrl": "https://docs.google.com/presentation/d/13aVyzWa3DGeUQeDMNBnQl6IHonmsrTJ9ILi2UI0sZwo/edit?usp=sharing"}, {"id": "f002", "theme": "1. Drive Adoption", "themeNumber": 1, "program": "MCE Convergence Tooling", "feature": "Consent syncing (finish email, sms, whatsapp)", "pmOwner": "Chad Jordan", "description": "Enable existing customers to easily manage consent for customers across Marketing Cloud Engagement (MCE) and Marketing on Core (MoC).", "goals": "", "engOwner": "Arun Kunhiraman Shyamaladevi Shreyas Diwan", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "Distinct Demo of This Feature", "considerations": "Convergence narrative; Careful framing & value-prop; Clear best practices and guidance for given persona(s); Make sure to take extra beats to connect dots/terms for customers; Consider showing demo/how-to example;  Intentional to quickly guide around any common issues or FAQ a customer might have", "demoLink": "Consent Mapping.mp4", "vidyardLink": "", "soLink": "262 Solution Overview: Marketing Cloud Consent Mapping", "pmmSlide": "", "customerValue": "", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Organizations running both MCE and MC Next face a critical gap: consent status isn't synchronized between platforms, creating compliance risk and inconsistent subscriber experiences during migration.<br><br><strong>What's New:</strong> Consent Mapping automatically synchronizes opt-in/opt-out status for email, SMS, and WhatsApp between MCE and Marketing on Core. When a subscriber updates consent in either platform, it propagates in real-time.<br><br><strong>How to Demo:</strong> Walk through the Consent Mapping setup in Marketing Setup \u2192 show the channel-by-channel mapping configuration. Then demonstrate: update consent in MCE \u2192 verify it appears in MC Next (and vice versa). Emphasize the convergence narrative \u2014 this is the bridge for customers migrating to MC Next.<br><br><strong>Customer Value:</strong> Eliminates the #1 convergence blocker for MCE customers. Ensures compliance across both platforms during migration. No more manual consent data syncs or risk of messaging opted-out contacts.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_consent.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"regulated": "<strong>Regulated Industries Angle:</strong> For FINS customers, consent synchronization is a regulatory requirement \u2014 not a nice-to-have. A subscriber who opts out in one system must be honored everywhere. Demo the sync for SMS/WhatsApp consent which is critical for TCPA compliance. Highlight the audit-ready synchronization logs."}, "demoUrl": "https://drive.google.com/file/d/1FJFvKLjZgFIG9YPnyBIxzMrVpLJLmhTj/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1qlTNEZl7niwQlRRVrJ5I2nik6k16uKqPFgeCDARxvzQ/edit?usp=sharing"}, {"id": "f003", "theme": "1. Drive Adoption", "themeNumber": 1, "program": "MCE Convergence Tooling", "feature": "Share MCE Email From Domains", "pmOwner": "Scott Walls", "description": "MCE+ customers are able to re-use existing, authenticated sending domains in MC Next, maintaining their established sender reputation for new campaigns", "goals": "The goal of the convergence effort is to reduce redundant setup time, ensure immediate brand consistency across applications, and preserve sending reputation of email marketing domains established in MCE when customers move to MCE next architecture.", "engOwner": "Liu Sun Amaresh Dwivedi Fahad Mudassar Raja Duddupudi", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "Distinct Demo of This Feature", "considerations": "Convergence narrative; Careful framing & value-prop; Clear best practices and guidance for given persona(s); Make sure to take extra beats to connect dots/terms for customers; Consider showing demo/how-to example;  Intentional to quickly guide around any common issues or FAQ a customer might have", "demoLink": "Internal Demo:        [262] Summer '26 Share MCE Email Sending Domains to MCE+ Initial Demo    Customer Demo:     [262] Share MCE Email Sending Domain with MCE+", "vidyardLink": "", "soLink": "MC Summer '26 Release Highlights Deck &   Share MCE Email Sending Domains with MCE+", "pmmSlide": "", "customerValue": "", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> MCE customers moving to MC Next lose their authenticated sending domains, forcing them to rebuild domain reputation from scratch \u2014 which tanks deliverability and delays migration timelines.<br><br><strong>What's New:</strong> You can now share authenticated MCE sending domains directly with MC Next. Your existing SPF, DKIM, and DMARC configurations carry over, preserving sender reputation and inbox placement.<br><br><strong>How to Demo:</strong> Show the domain sharing workflow: MCE Domain Management \u2192 select domain \u2192 share with MC Next org. Then show the domain appearing in MC Next's Unified Messaging settings, ready to use immediately. Emphasize zero re-authentication needed.<br><br><strong>Customer Value:</strong> Preserves years of sender reputation built in MCE. Eliminates weeks of domain warmup when migrating. Customers can start sending from MC Next on day one with their trusted domain identity.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_data.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "demoUrl": "https://drive.google.com/file/d/1e_urd9Uw-7UXwOR7dn3P_tRkyOfEhXih/view", "soUrl": "https://docs.google.com/presentation/d/1C2Q5A-FZg0jYd_MOobLPnOxS2-vGU5ug7F9gf5YYnSo/edit?slide=id.g3da47770219_1_1852&pli=1"}, {"id": "f004", "theme": "1. Drive Adoption", "themeNumber": 1, "program": "MCN as a CPaaS for Salesforce", "feature": "Setup on Salesforce Go", "pmOwner": "Anuj Goyal", "description": "Enable channel setup discovery from Go which includes SMS, WhatsApp, Mobile App, RCS and Web Push. Based on add-on licenses utilize PLG motion and show channel setup as available / unavailable (locked).", "goals": "Adoption - Cross-Cloud customers and leverage Go for Marketing Setup. Engagement - Utilize Go feature pages to enable Marketing functionalities.", "engOwner": "Santosh Vaidyanathan Ravi Chanchlani", "targetRelease": "262", "actualRelease": "", "demoType": "PM Discretion", "coverageType": "Distinct Demo of This Feature", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "", "vidyardLink": "", "soLink": "262 (Summer '26) MC Growth / Advanced: Setup Solution Overview", "pmmSlide": "", "customerValue": "", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Setting up marketing channels (SMS, WhatsApp, Push, RCS) requires navigating multiple setup screens, and cross-cloud customers often don't know where to start.<br><br><strong>What's New:</strong> Salesforce Go now includes channel setup discovery for Marketing Cloud, showing available and locked channels based on your licenses. It provides a guided, PLG-style onboarding experience.<br><br><strong>How to Demo:</strong> Open Salesforce Go \u2192 navigate to Marketing Setup. Show the channel cards (SMS, WhatsApp, Mobile App, RCS, Web Push) with their enabled/locked states. Walk through the guided setup flow for one channel. Emphasize the cross-cloud discovery \u2014 Service Cloud and Sales Cloud customers can see what Marketing capabilities are available.<br><br><strong>Customer Value:</strong> Dramatically reduces time-to-value for new Marketing Cloud customers. Cross-cloud customers discover and activate marketing channels they didn't know they had access to.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_campaigns.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "soUrl": "https://docs.google.com/presentation/d/1R6PJ6j_JysCxIINSgCLtyAVlGvFVSxZEmBOl7yb0mPM/edit?slide=id.g37646e1581c_0_4"}, {"id": "f005", "theme": "1. Drive Adoption", "themeNumber": 1, "program": "MCN as a CPaaS for Salesforce", "feature": "Email Channel Foundations Enhancements (seamless upgrade/downgrade)", "pmOwner": "Eric Hannon", "description": "Ability to seamlessly upgrade/downgrade editions given the different capabilities and commerical models. Reduce provisioning errors. Expand cross-cloud use cases.", "goals": "Reduce upgrade/downgrade errors, Foundations becomes a viable commercial vehicle for enabling min required messaging capabilities for x-cloud email use cases", "engOwner": "Fahad Mudassar", "targetRelease": "262", "actualRelease": "", "demoType": "Apps&Ind Only", "coverageType": "N/A", "considerations": "N/A", "demoLink": "", "vidyardLink": "", "soLink": "FY'27 Solution Overview Guide (INTERNAL) - Foundations Enhancements", "pmmSlide": "", "customerValue": "", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Upgrading or downgrading between Marketing Cloud editions (Foundations, Growth, Advanced) causes provisioning errors, and cross-cloud teams using basic email capabilities face unnecessary friction.<br><br><strong>What's New:</strong> Seamless edition transitions with zero provisioning errors. Foundations becomes a viable commercial vehicle for enabling minimum required messaging capabilities for cross-cloud email use cases (Service Cloud email, Commerce notifications).<br><br><strong>How to Demo:</strong> This is primarily an internal/Apps & Industries demo. Show the clean upgrade path from Foundations \u2192 Growth \u2192 Advanced with no data loss or configuration breaks. Highlight cross-cloud use cases: a Service Cloud agent triggering a transactional email without needing full Marketing Cloud.<br><br><strong>Customer Value:</strong> Removes friction from the upgrade journey. Cross-cloud teams get basic email capabilities immediately, with a clear path to expand.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_data.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "soUrl": "https://docs.google.com/presentation/d/1FyWY2GxbRKRu2knLkB2t1DorPasiTyBID1awIEBTAAA/edit?usp=sharing"}, {"id": "f006", "theme": "1. Drive Adoption", "themeNumber": 1, "program": "Owned Channels - Email", "feature": "Email Archiving", "pmOwner": "Eric Hannon", "description": "As a Marketing Manager/Admin, for regulatory/legal compliance reasons, I need a copy of every email sent including personalizations and images and archived into storage in case my organization is ever audited", "goals": "Product Market Fit for DM2.0 & any MCN FINS senders  Closes parity gap with MCE & removes a top 5 adoption barrier for MCAE+ customers", "engOwner": "Fahad Mudassar Raja Duddupudi", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "PM Discretion for Distinct Demo of This Feature or Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "Email Archive demo presentation-1.webm  Email Archiving Demo - Internal only - With PM Intro", "vidyardLink": "", "soLink": "Solution Overview Guide (INTERNAL) - Email Archiving", "pmmSlide": "", "customerValue": "", "persona": "Marketing Manager", "pmmLead": "", "cxLead": "", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Regulated industries and enterprise customers need a complete, tamper-proof archive of every email sent \u2014 including personalized content and rendered images \u2014 for legal discovery and compliance audits. This was a top-5 adoption barrier for MCAE+ customers.<br><br><strong>What's New:</strong> Email Archiving in MC Next stores a rendered copy of every sent email (with all personalizations resolved) into the EmailMessage standard object. An archive app provides cost-efficient storage and export capabilities.<br><br><strong>How to Demo:</strong> Enable archiving in Unified Messaging settings \u2192 send a personalized email \u2192 navigate to the archive \u2192 show the fully-rendered email with resolved merge fields. Demonstrate the export functionality for legal/compliance handoff.<br><br><strong>Customer Value:</strong> Closes a top-5 MCE parity gap. Satisfies regulatory requirements for SEC, FINRA, HIPAA, and GDPR right-of-access. Eliminates the need for third-party email archiving solutions.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_data.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"high-tech": "<strong>High-Tech Angle:</strong> Tech companies with SOC2 compliance requirements or those in pre-IPO stages need email archiving to demonstrate communication governance. Show how engineering-led marketing teams can enable archiving without additional tooling.", "regulated": "<strong>Regulated Industries Angle:</strong> This is a deal-breaker feature for FINS. SEC Rule 17a-4 and FINRA 3110 require broker-dealers to retain all business communications. For healthcare, HIPAA requires retention of patient communications. Demo the archive search, the rendered email view, and the export-to-compliance-system workflow. Emphasize the tamper-proof storage model."}, "demoUrl": "https://drive.google.com/file/d/1V37FxpOUgrLi0YOyeBe6xZGno-v6ZYQb/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1KM0QgDNQ2zSMQafp1g1fzsqfTLkZtA1d3fkS0jSdt3g/edit?slide=id.g27237791d76_0_2106"}, {"id": "f007", "theme": "1. Drive Adoption", "themeNumber": 1, "program": "Owned Channels - Email", "feature": "Email Dynamic From / Reply", "pmOwner": "Eric Hannon", "description": "Emails can be configured with a dynamic From (such as {account owner}) and replies can be routed to dynamic individuals (such as {account owner email}), for more personalized B2B email marketing", "goals": "Close parity gap with MCE & remove a top 5 adoption barrier for MCAE+ customers", "engOwner": "Fahad Mudassar", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "Dynamic From/replyto demo-5/1/2026, 5:29\u202fPM.mp4", "vidyardLink": "", "soLink": "Solution Overview Guide (INTERNAL) - Dynamic From/Reply", "pmmSlide": "", "customerValue": "", "persona": "B2B Marketer", "pmmLead": "", "cxLead": "", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> B2B marketers need emails to appear from the assigned account owner \u2014 not a generic marketing address \u2014 to build trust and drive replies. Static 'from' addresses reduce open rates and feel impersonal in complex sales cycles.<br><br><strong>What's New:</strong> Dynamic From and Reply-To let you use CRM field references (like {Account Owner}) as the email sender and reply routing. Replies go directly to the right person \u2014 the account exec, the CSM, or the assigned rep.<br><br><strong>How to Demo:</strong> In the email editor, configure the From field using a merge field \u2192 {!Contact.Owner.Name}. Set Reply-To to {!Contact.Owner.Email}. Send a test \u2192 show it arrives 'from' the account owner, and replies route to them. Emphasize the B2B personalization at scale.<br><br><strong>Customer Value:</strong> Closes a critical MCAE parity gap. Increases open rates by 20-30% (industry benchmarks for personalized senders). Makes B2B email feel like 1:1 outreach at campaign scale.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_data.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"high-tech": "<strong>High-Tech Angle:</strong> For SaaS companies running ABM motions, Dynamic From is the difference between a marketing email that gets ignored and an email from 'their account exec' that gets a meeting. Demo alongside Account Discovery Agent for the full ABM story.", "regulated": "<strong>Regulated Industries Angle:</strong> Financial advisors need client communications to come from the named advisor, not a marketing team. Dynamic From enables compliant, personalized outreach while maintaining centralized marketing control and approval workflows."}, "demoUrl": "https://drive.google.com/file/d/14J-0bb7aMHLkikWpYqulBN1EddiWG8h4/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1He8gCF18wNIgHU5caZSqZzqzs8rAm-Fupm-coAZ9Ljk/edit?slide=id.g27237791d76_0_2106"}, {"id": "f008", "theme": "1. Drive Adoption", "themeNumber": 1, "program": "Owned Channels - Email", "feature": "[Email] MCE Tracking UI Uplift", "pmOwner": "Sharbari Shau", "description": "This project uplifts the customer-facing Tracking UI \u2018Summary widget\u2019 to surface previously hidden 'Not Sent' metrics (such as duplicates, held status, and list detective exclusions) for better data transparency.", "goals": "Addresses top MCE attrition risk", "engOwner": "Akshay Desai", "targetRelease": "262", "actualRelease": "", "demoType": "Apps&Ind Only", "coverageType": "N/A", "considerations": "N/A", "demoLink": "Marketing-release 262 [Email] MCE Tracking UI Uplift.mp4", "vidyardLink": "", "soLink": "Solution Overview - Tracking UI Uplift in MCE", "pmmSlide": "", "customerValue": "", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> MCE customers can't see why emails weren't sent \u2014 duplicates, held contacts, and list detective exclusions are hidden, making it impossible to diagnose delivery issues. This is the #1 MCE attrition risk.<br><br><strong>What's New:</strong> The Tracking UI Summary widget now surfaces all 'Not Sent' metrics: duplicates removed, contacts held, list detective exclusions, and other suppression reasons. Full transparency into email delivery pipeline.<br><br><strong>How to Demo:</strong> Navigate to a sent email's tracking page in MCE \u2192 show the uplifted Summary widget with the new 'Not Sent' breakdown. Explain each category (duplicates, held, list detective). Emphasize: 'This is the data your MCE customers have been asking for.'<br><br><strong>Customer Value:</strong> Directly addresses the top MCE attrition risk. Gives marketers confidence in their send pipeline. Eliminates 'where did my emails go?' support tickets.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_marketing_engagement.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "demoUrl": "https://drive.google.com/file/d/1EDLIrsishhSQQF3akh-ydZdh3w2pqOXT/view?usp=drive_link", "soUrl": "https://docs.google.com/presentation/d/1vXVDOdAG75l8EzRJhE85Y_vju_dTa7-dJNCI-SZjwzw/edit?slide=id.g3da1acf66eb_0_1927"}, {"id": "f009", "theme": "1. Drive Adoption", "themeNumber": 1, "program": "Owned Channels - Email", "feature": "CC", "pmOwner": "Urvashi Jain", "description": "The absence of foundational CC impairs B2B marketing effectiveness by preventing customers from involving critical decision-support groups. This gap is a long-standing customer expectation and basic email standard that risks platform utility for complex sales cycles and competitive differentiation.", "goals": "Support internal and external cc in send email invokable action  Close parity gap with MCE & remove a top 5 adoption barrier for MCAE+ customers", "engOwner": "Fahad Mudassar", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "Marketing-Release 262-CC and Synthetic CC-.mov", "vidyardLink": "", "soLink": "Solution Overview CC and Synthetic CC", "pmmSlide": "", "customerValue": "", "persona": "B2B Marketer", "pmmLead": "", "cxLead": "", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> B2B marketers can't CC decision-support groups (legal, finance, procurement) on marketing emails \u2014 a basic email standard that's critical for complex enterprise sales cycles. This was a top-5 MCAE+ adoption barrier.<br><br><strong>What's New:</strong> CC support in the Send Email invocable action, supporting both internal and external CC recipients. Up to 10 CC addresses per email send.<br><br><strong>How to Demo:</strong> In a Marketing Flow, configure the Send Email action \u2192 add CC recipients (show both static and dynamic CC fields). Send a test \u2192 show the email arrives with the CC'd parties visible. Emphasize: 'A basic email standard, finally available in MC Next.'<br><br><strong>Customer Value:</strong> Closes a top-5 MCAE parity gap. Enables complex B2B sales cycles where multiple stakeholders need visibility. Account teams stay informed without additional workflows.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_data.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"high-tech": "<strong>High-Tech Angle:</strong> For enterprise software deals with procurement teams and legal review, CC enables marketing to keep the entire buying committee informed on product updates, renewal notices, and onboarding communications.", "regulated": "<strong>Regulated Industries Angle:</strong> In wealth management and insurance, regulatory communications often require a compliance officer or supervisor to be CC'd on client correspondence. This feature enables that workflow natively \u2014 no workarounds needed."}, "demoUrl": "https://drive.google.com/file/d/1gfUFVyCOXlkJTLuv0jGKH7XMflXJQsOF/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1O-8naC0_BLhRMJiexUTpNTmfNWrBqf2nDzWFJp4mrAo/edit?slide=id.g27237791d76_0_2106"}, {"id": "f010", "theme": "1. Drive Adoption", "themeNumber": 1, "program": "Owned Channels - Email", "feature": "Synthetic CC", "pmOwner": "Urvashi Jain", "description": "Allow recipients to visually see that account teams were copied on email communications, but avoid physically delivering CC emails unless the recipient replies (avoiding overwhelming account team inboxes)", "goals": "Deliver customer committment for Goldman Sachs, WEF", "engOwner": "Fahad Mudassar", "targetRelease": "262", "actualRelease": "", "demoType": "PM Discretion", "coverageType": "Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "Marketing-Release 262-CC and Synthetic CC-.mov", "vidyardLink": "", "soLink": "Solution Overview CC and Synthetic CC", "pmmSlide": "", "customerValue": "", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Account teams want to appear CC'd on marketing emails to maintain the appearance of a coordinated outreach \u2014 but physically delivering every CC email to the account team would overwhelm their inboxes.<br><br><strong>What's New:</strong> Synthetic CC shows CC'd parties in the email header without physically delivering the email to them \u2014 unless the recipient replies. Only reply-triggered delivery reaches the CC'd contacts.<br><br><strong>How to Demo:</strong> Configure Synthetic CC alongside the standard CC feature \u2192 send a test \u2192 show the recipient sees the account team in CC, but the account team's inbox only receives the email if the recipient replies. Highlight the Goldman Sachs and WEF use case \u2014 built for enterprise requirements.<br><br><strong>Customer Value:</strong> Best of both worlds: recipients see a coordinated team approach, account teams aren't buried in CC volume. Purpose-built for enterprise B2B at scale.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_data.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"regulated": "<strong>Regulated Industries Angle:</strong> Goldman Sachs and WEF specifically requested this. For wealth management, the advisor appears CC'd on all marketing communications without inbox overload. The reply-triggered delivery ensures they only see emails that need a response."}, "demoUrl": "https://drive.google.com/file/d/1gfUFVyCOXlkJTLuv0jGKH7XMflXJQsOF/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1O-8naC0_BLhRMJiexUTpNTmfNWrBqf2nDzWFJp4mrAo/edit?slide=id.g27237791d76_0_2106"}, {"id": "f011", "theme": "2. B2B Revenue Support", "themeNumber": 2, "program": "B2B Table Stakes", "feature": "B2BMA on UMI - ABM Dashboard", "pmOwner": "Brian Moore", "description": "Delivers ABM analytics on the Unified Marketing Intelligence framework, harmonizing core B2B objects with multi-channel engagement data. Provides a unified view of target account performance to identify \"Top Accounts\" for outreach. Delivered as an entitlement within the MI Add-On SKU.  Going into 262.11 patch release using 264 capacity.", "goals": "-Migrate users from CRMA -Deliver cross-channel view of target account engagement -Track engagement, pipeline, and opportunity influence across top accounts with improved data accuracy -Identify pipeline value across top accounts and keep their ABM efforts on track", "engOwner": "Sharon Bar", "targetRelease": "262", "actualRelease": "262.11", "demoType": "Customer-Facing Demo", "coverageType": "PM Discretion for Distinct Demo of This Feature or Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "B2B Analytics for Marketers - ABM Dashboard.mp4 Pending Apps & Industries version. Demo ETA: 5/15", "vidyardLink": "", "soLink": "262 Marketing Intelligence Solution Overview", "pmmSlide": "Next Gen B2B Analytics - Customer Facing Deck", "customerValue": "OOTB Account-Based Marketing Dashboards built for MC Advanced & operating on UMI, leveraging Data 360 and Tableau Next as the visualization layer", "persona": "B2B Marketer", "pmmLead": "Ruth Bolster Aurelia Solomon", "cxLead": "", "pft": "Intelligence", "releaseStatus": "Generally Available", "talkTrack": "<strong>Business Problem:</strong> ABM marketers lack a unified view of target account engagement across channels. Legacy CRMA dashboards are fragmented and don't connect marketing touchpoints to pipeline influence.<br><br><strong>What's New:</strong> Out-of-the-box ABM Dashboard on the Unified Marketing Intelligence (UMI) framework, built for MC Advanced. Harmonizes core B2B objects with multi-channel engagement data using Data 360 and Tableau Next. Identifies 'Top Accounts' for outreach based on cross-channel engagement signals.<br><br><strong>How to Demo:</strong> Navigate to Marketing Intelligence \u2192 ABM Dashboard. Walk through: Top Accounts ranking, engagement heatmap by channel, pipeline influence metrics. Show drill-down from an account \u2192 engagement timeline. Emphasize the unified view: 'One dashboard, every touchpoint, real-time.'<br><br><strong>Customer Value:</strong> Replaces fragmented CRMA dashboards. Gives ABM teams a single source of truth for account engagement. Identifies which accounts are 'heating up' before they enter pipeline.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_segments.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"high-tech": "<strong>High-Tech Angle:</strong> For SaaS companies running ABM, this dashboard is the command center. Show how it connects product-led signals (website visits, content downloads) with sales engagement to identify product-qualified accounts ready for outreach.", "regulated": "<strong>Regulated Industries Angle:</strong> For financial services firms, ABM targets institutional investors and corporate treasury teams. The dashboard shows which accounts are engaging with thought leadership content, event invitations, and market insights \u2014 giving relationship managers prioritized outreach lists."}, "demoUrl": "https://drive.google.com/file/d/1g4y4fKBKxMsQVx4Er2au4CwcD_ff2KJb/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1RlfFFy5ZMG6kbfm7tG7vlPiaDy7qSLh2P1jN5m7GsgI/edit?slide=id.g3d49b375dd6_0_23", "pmmSlideUrl": "https://docs.google.com/presentation/d/1kIsxWh48Vyc_E3vUzOuWcRGyPPP3lm-4zkCxpxxvB9I/edit?slide=id.g3d3b4f7d148_2_973"}, {"id": "f012", "theme": "2. B2B Revenue Support", "themeNumber": 2, "program": "B2B Table Stakes", "feature": "B2BMA on UMI - Pipeline Dashboard", "pmOwner": "Brian Moore", "description": "Re-platforms the B2B Pipeline view onto the Unified Marketing Intelligence framework to achieve feature parity with legacy B2BMA. Visualizes the end-to-end sales funnel to demonstrate marketing impact on revenue.  Going into 262.11 patch release using 264 capacity.", "goals": "-Deliver comprehensive B2B pipeline dashboard on UMI framework -Migrate workflows from legacy B2BMA to MI and Data Cloud -Connect campaign engagement to sales opportunities", "engOwner": "Sharon Bar", "targetRelease": "262", "actualRelease": "262.11", "demoType": "Customer-Facing Demo", "coverageType": "PM Discretion for Distinct Demo of This Feature or Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "B2B Analytics for Marketers - Pipeline Dashboard.mp4 - Pending Apps & Industries version. Demo ETA: 5/15", "vidyardLink": "", "soLink": "262 Marketing Intelligence Solution Overview", "pmmSlide": "Next Gen B2B Analytics - Customer Facing Deck", "customerValue": "OOTB Pipeline Dashboard built for MC Advanced operating on UMI, leveraging Data 360 and Tableau Next as the visualization layer.", "persona": "B2B Marketer", "pmmLead": "Ruth Bolster Aurelia Solomon", "cxLead": "", "pft": "Intelligence", "releaseStatus": "Generally Available", "talkTrack": "<strong>Business Problem:</strong> Marketing teams can't demonstrate their impact on revenue. Legacy B2BMA pipeline views don't connect campaign engagement to sales outcomes on a modern analytics framework.<br><br><strong>What's New:</strong> Re-platformed B2B Pipeline Dashboard on UMI, achieving feature parity with legacy B2BMA. Visualizes the complete sales funnel from first touch through closed-won, powered by Data 360 and Tableau Next.<br><br><strong>How to Demo:</strong> Open the Pipeline Dashboard \u2192 walk through the funnel stages (MQL \u2192 SQL \u2192 Opportunity \u2192 Closed Won). Show marketing-sourced vs. marketing-influenced pipeline. Demonstrate the stage conversion metrics. Emphasize: 'This is the CMO's favorite dashboard \u2014 it proves marketing ROI.'<br><br><strong>Customer Value:</strong> Finally proves marketing's contribution to revenue. Migrates teams from legacy B2BMA to the modern UMI framework. Gives CMOs the data they need for board-level reporting.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_segments.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "demoUrl": "https://drive.google.com/file/d/1ENq7UdXiFcFnezM5NGYDPA3s-u6vGreK/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1RlfFFy5ZMG6kbfm7tG7vlPiaDy7qSLh2P1jN5m7GsgI/edit?slide=id.g3d49b375dd6_0_23", "pmmSlideUrl": "https://docs.google.com/presentation/d/1kIsxWh48Vyc_E3vUzOuWcRGyPPP3lm-4zkCxpxxvB9I/edit?slide=id.g3d3b4f7d148_2_954"}, {"id": "f013", "theme": "2. B2B Revenue Support", "themeNumber": 2, "program": "B2B Table Stakes", "feature": "B2BMA on UMI - Marketing Manager Dashboard", "pmOwner": "Brian Moore", "description": "going into . releases using 264 capacity", "goals": "-Surfaces insights on campaign, pipeline, and Account-Based Marketing dashboard performance -View Opportunities in Pipeline, Revenue, and Average Conversion to Close", "engOwner": "Sharon Bar", "targetRelease": "262", "actualRelease": "262.13", "demoType": "Customer-Facing Demo", "coverageType": "PM Discretion for Distinct Demo of This Feature or Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "B2B Analytics for Marketers - Marketing Manager Demo.mp4 - Pending Apps & Industries version. Demo ETA: 5/15", "vidyardLink": "", "soLink": "262 Marketing Intelligence Solution Overview", "pmmSlide": "Next Gen B2B Analytics - Customer Facing Deck", "customerValue": "OOTB Marketing Manager Dashboard built for MC Advanced operating on UMI, leveraging Data 360 and Tableau Next as the visualization layer.", "persona": "", "pmmLead": "Ruth Bolster Aurelia Solomon", "cxLead": "", "pft": "Intelligence", "releaseStatus": "Generally Available", "talkTrack": "<strong>Business Problem:</strong> Marketing managers need a single view of campaign performance, pipeline health, and ABM results \u2014 not three separate dashboards in a legacy system.<br><br><strong>What's New:</strong> A unified Marketing Manager Dashboard on UMI that surfaces campaign insights, pipeline opportunities, revenue data, and average conversion-to-close metrics in one view. Built for MC Advanced using Data 360 and Tableau Next.<br><br><strong>How to Demo:</strong> Open the Marketing Manager Dashboard \u2192 show the high-level KPIs (opportunities in pipeline, revenue attributed, avg conversion time). Drill into a specific campaign \u2192 show the engagement-to-pipeline flow. Emphasize the modern Tableau Next visualization layer.<br><br><strong>Customer Value:</strong> One dashboard for the marketing manager's daily workflow. No more toggling between CRMA views. Real-time data from UMI ensures decisions are based on current pipeline reality.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_segments.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "demoUrl": "https://drive.google.com/file/d/1enE_JXvzSvt65v7EarPDH5hDmz11ocKC/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1RlfFFy5ZMG6kbfm7tG7vlPiaDy7qSLh2P1jN5m7GsgI/edit?slide=id.g3d49b375dd6_0_23", "pmmSlideUrl": "https://docs.google.com/presentation/d/1kIsxWh48Vyc_E3vUzOuWcRGyPPP3lm-4zkCxpxxvB9I/edit?slide=id.g3d3b4f7d148_2_991"}, {"id": "f014", "theme": "2. B2B Revenue Support", "themeNumber": 2, "program": "B2B Table Stakes", "feature": "B2BMA on UMI - B2B Attribution", "pmOwner": "Brian Moore", "description": "going into . releases using 264 capacity", "goals": "-View closed-won revenue to engagement with marketing assets -Leverage Unified Marketing Intelligence to view atribution across different models including first-touch, last-touch, U-shaped, and W-shaped models.", "engOwner": "Sharon Bar", "targetRelease": "262", "actualRelease": "262.13", "demoType": "Customer-Facing Demo", "coverageType": "PM Discretion for Distinct Demo of This Feature or Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "B2B Analytics for Marketers - B2B Attribution.mp4 Pending Apps & Industries version. Demo ETA: 5/15", "vidyardLink": "", "soLink": "262 Marketing Intelligence Solution Overview", "pmmSlide": "Next Gen B2B Analytics - Customer Facing Deck", "customerValue": "OOTB B2B Multi-Touch Attribution, built on Marketing Intelligence's core attribution engine, providing a newer attribution model that includes First Touch, Last Touch, Linear (Even Distribution), models, but now includes net-new models U-shaped, and W-shaped. Built for MC Advanced, operating on UMI, and leveraging Data 360 and Tableau Next.", "persona": "", "pmmLead": "Ruth Bolster Aurelia Solomon", "cxLead": "", "pft": "Intelligence", "releaseStatus": "Generally Available", "talkTrack": "<strong>Business Problem:</strong> B2B attribution is notoriously difficult \u2014 most tools only offer first-touch or last-touch models, missing the complex multi-touch reality of enterprise buying journeys.<br><br><strong>What's New:</strong> Multi-touch attribution models on UMI including First Touch, Last Touch, Linear (Even Distribution), plus new U-shaped and W-shaped models. Connects closed-won revenue to engagement with marketing assets across the full journey. Built on Marketing Intelligence's core attribution engine.<br><br><strong>How to Demo:</strong> Navigate to B2B Attribution \u2192 select a closed-won deal \u2192 show attribution across models (switch between First Touch, U-shaped, W-shaped). Demonstrate how the same deal credits different touchpoints depending on the model. Emphasize: 'U-shaped emphasizes first and last touch, W-shaped adds the opportunity creation moment.'<br><br><strong>Customer Value:</strong> The most comprehensive B2B attribution available on a native Salesforce analytics framework. U-shaped and W-shaped models reflect how enterprise deals actually close \u2014 multiple touches across months. Gives marketing leaders data to optimize spend allocation.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_segments.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"high-tech": "<strong>High-Tech Angle:</strong> For SaaS companies with 6-12 month sales cycles, W-shaped attribution is transformative \u2014 it reveals whether product demos, trial signups, or content downloads are the real pipeline drivers, beyond just first and last touch."}, "demoUrl": "https://drive.google.com/file/d/1U_Xjnz6SMdLz7qHneVLWJGS4Z3pk0rPG/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1RlfFFy5ZMG6kbfm7tG7vlPiaDy7qSLh2P1jN5m7GsgI/edit?slide=id.g3d49b375dd6_0_23", "pmmSlideUrl": "https://docs.google.com/presentation/d/1kIsxWh48Vyc_E3vUzOuWcRGyPPP3lm-4zkCxpxxvB9I/edit?slide=id.g396c3d009d4_0_2753"}, {"id": "f015", "theme": "2. B2B Revenue Support", "themeNumber": 2, "program": "B2B Table Stakes", "feature": "Unified Engagement History Dashboards - Opportunity Record", "pmOwner": "Brian Moore", "description": "Dashboard Enablement Dashboard Page Views vs. Legacy", "goals": "Brian Moore", "engOwner": "Maria Rivera", "targetRelease": "262", "actualRelease": "", "demoType": "", "coverageType": "", "considerations": "", "demoLink": "Feature targeted for 262.14 patch release. Pending demo-able E2E flow. Initial Demo ETA: week of 5/18", "vidyardLink": "", "soLink": "[262] Summer '26 - Marketing - UEHD Opportunity Records  Solution Overview", "pmmSlide": "", "customerValue": "Next-gen Unified Engagement History Dashboards for Opportunity records provide sales & marketing users with up-to-date engagement history leveraging a lightning web component that's easy to setup on record pages, and leverages Data 360 and Tableau Next as read-only dashboards.", "persona": "", "pmmLead": "Ruth Bolster Aurelia Solomon", "cxLead": "", "pft": "Intelligence", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Sales reps viewing an Opportunity record can't see what marketing touchpoints influenced the deal \u2014 email opens, form fills, web visits are invisible at the opportunity level.<br><br><strong>What's New:</strong> Unified Engagement History Dashboard embedded directly on Opportunity record pages as a Lightning Web Component. Displays email engagement, form submissions, and web activity tied to the opportunity's contacts. Powered by Data 360 and Tableau Next as read-only dashboards.<br><br><strong>How to Demo:</strong> Navigate to an Opportunity record \u2192 scroll to the Engagement History section \u2192 show the timeline of marketing touches across contacts on the deal. Emphasize: 'Sales reps see this without leaving the opportunity. No login to a separate analytics tool.'<br><br><strong>Customer Value:</strong> Bridges the sales-marketing divide. Reps understand which marketing content influenced the deal, informing their conversation strategy. Easy setup \u2014 just add the LWC to the record page layout.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_unified_engagement_history_dashboard_opportunity.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "soUrl": "https://docs.google.com/presentation/d/1v7J9qzfWGl0hvYEAT6QmwppJKH_bgrslyxzhjFPKqmc/edit?slide=id.g3ade3dcc9be_0_1915"}, {"id": "f016", "theme": "2. B2B Revenue Support", "themeNumber": 2, "program": "B2B Table Stakes", "feature": "Tracking Enhancements - , reporting, mult. banners", "pmOwner": "Lucie de Castrique", "description": "Support multiple banner designs to enable variations per Site & per web embed code.", "goals": "1) Number of Banners: 50% of our MC Next customers are actively honoring consent signals and using a consent banner 2) Percent of accounts who have viewed this report at least once in the past month >10%", "engOwner": "Emily Fitzgerald", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "Distinct Demo of This Feature", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "MCB_Demo E2E 1 2.40.18\u202fPM.mp4", "vidyardLink": "", "soLink": "Multiple Consent Banners - Solution Overview", "pmmSlide": "", "customerValue": "Admins can create multiple consent banners in CMS and assign them to specific sites or embed codes. Legacy banners are read-only and continue rendering until replaced, with a new centralized setup page for managing assignments.", "persona": "Marketing Admin", "pmmLead": "Megan Cohn", "cxLead": "Emily Bradley", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Companies with multiple websites and embed codes need different consent banners for each \u2014 but today you're limited to a single banner design across all properties.<br><br><strong>What's New:</strong> Create and manage multiple consent banners in CMS, each assignable to specific sites or web embed codes. Legacy banners remain active (read-only) until explicitly replaced. New centralized setup page for managing all banner assignments.<br><br><strong>How to Demo:</strong> Navigate to the new consent banner management page \u2192 create two different banners (e.g., corporate site vs. product blog). Assign each to their respective embed codes. Preview both banners. Emphasize the centralized management and the non-disruptive migration from legacy banners.<br><br><strong>Customer Value:</strong> Finally supports multi-brand and multi-site consent strategies. Each website gets a purpose-optimized banner. Centralized management reduces admin overhead.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_consent.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"regulated": "<strong>Regulated Industries Angle:</strong> GDPR and ePrivacy Directive require consent banners tailored to jurisdiction and purpose. A wealth management firm can now have distinct banners for their institutional investor portal vs. retail banking site, each with jurisdiction-appropriate consent language.", "retail-mfg": "<strong>Retail & Manufacturing Angle:</strong> Multi-brand retailers (e.g., a parent company with 5 consumer brands) can deploy unique, brand-consistent consent banners for each brand's website \u2014 maintaining distinct brand identities while managing consent centrally."}, "demoUrl": "https://drive.google.com/file/d/1WCdXZYBPM6wW0OZhpT0DvSeqG74hN1u-/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1Isa1lhAtVjPafU7MPDuloncq5iOMzJ_OxWGLbjzGAGA/edit?slide=id.g3dc9fef2c8a_0_1889"}, {"id": "f017", "theme": "2. B2B Revenue Support", "themeNumber": 2, "program": "Flow for B2B", "feature": "Social Posting - LinkedIn", "pmOwner": "Blake Manosh", "description": "Close critical feature parity gap to allow B2B marketers to post messages to LinkedIn", "goals": "Enable and maximize sales to customer who require a solution that includes social media management.", "engOwner": "Matt Jones", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "Distinct Demo of This Feature", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "Campaign-Social-Posts-LinkedIn.mov", "vidyardLink": "", "soLink": "MC Social Posting - FY'27 Solution Overview", "pmmSlide": "", "customerValue": "", "persona": "Marketing Manager", "pmmLead": "", "cxLead": "", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> B2B marketers manage LinkedIn posting separately from their campaign workflow. There's no native way to schedule and publish LinkedIn posts alongside email, SMS, and other channels in Marketing Cloud.<br><br><strong>What's New:</strong> Native LinkedIn social posting from Marketing Cloud campaigns. Create, schedule, and publish LinkedIn posts directly from the campaign record. Closes a critical parity gap for B2B social strategy.<br><br><strong>How to Demo:</strong> Open a Campaign \u2192 navigate to Social Posting \u2192 connect LinkedIn company page \u2192 compose a post with image/link preview \u2192 schedule it. Show the post appearing in the campaign activity timeline alongside email sends. Emphasize the multi-channel orchestration: 'Email + LinkedIn in one campaign workflow.'<br><br><strong>Customer Value:</strong> Eliminates LinkedIn as a disconnected channel. B2B marketers get a unified campaign experience. Engagement metrics flow back into the campaign for attribution.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_campaigns.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"high-tech": "<strong>High-Tech Angle:</strong> For SaaS companies where LinkedIn is the #1 B2B channel, this means product launch campaigns can coordinate email drips, LinkedIn posts, and sales outreach in a single campaign timeline. Demo a product launch campaign with synchronized LinkedIn + email."}, "demoUrl": "https://drive.google.com/file/d/1gY2WasvLD7PziP7oQpqyCZepmHSAFI36/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1E9XCPmegq3L18xbPf-g0JrzzyCyDuSGwAUTFkKLKAOE/edit?slide=id.g27237791d76_0_2117"}, {"id": "f018", "theme": "2. B2B Revenue Support", "themeNumber": 2, "program": "Flow for B2B", "feature": "Date Range Filter", "pmOwner": "Blake Markham", "description": "The ability to apply a date range filter directly on the Flow Builder canvas", "goals": "", "engOwner": "Nitika Aggarwal", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "Bundle Demo w/ Some Other Theme Features", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "ETA: Week of 5/18 (blocking issue )", "vidyardLink": "", "soLink": "Flow for Marketing - Summer '26 (262) Solution Overview", "pmmSlide": "", "customerValue": "", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Marketing on Core", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Marketers building flows can't filter by date ranges directly on the canvas \u2014 they need workarounds with custom formulas or downstream decision elements, adding complexity to simple time-based segmentation.<br><br><strong>What's New:</strong> A native Date Range Filter element on the Flow Builder canvas. Filter contacts by date fields (created date, last activity, custom dates) directly in the flow path without formula workarounds.<br><br><strong>How to Demo:</strong> Open Flow Builder \u2192 add a Date Range Filter element \u2192 configure it to filter contacts by 'Last Engagement Date in the past 30 days.' Show how it cleanly splits the flow path. Emphasize the simplicity: 'No more formula hacks for time-based filtering.'<br><br><strong>Customer Value:</strong> Reduces flow complexity. Makes time-based segmentation accessible to non-technical marketers. Fewer errors from formula workarounds.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_campaigns.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "demoUrl": "https://gus.my.salesforce.com/a07EE00002ZdUp5YAF", "soUrl": "https://docs.google.com/presentation/d/1rP8Mm5ePH4SfqYInhsg9huTeb-8ETzgT4wyjuFBFy38/edit?slide=id.g3dbf66137fe_0_37"}, {"id": "f019", "theme": "2. B2B Revenue Support", "themeNumber": 2, "program": "Optimize MoC for B2B", "feature": "List-Based Orchestration and Campaigns", "pmOwner": "Blake Markham", "description": "Allow for simple, scheduled, and batch orchestration to run against the CRM \"List\" entity. This will provide a faster path to value for our B2B users of MoC and provide a CRM-first experience that they can take advantage of  As of early March '26: Debug Support for List Triggered Flows is now part of 262, so \"Finish List Flows\" has been removed from 264.", "goals": "Reduce the adoption barrier for B2B customers and make it easier to set up a batch send against CRM records without the latencies resulting from Data Cloud", "engOwner": "Nitika Aggarwal", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "PM Discretion for Distinct Demo of This Feature or Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "E2E Summer Demo Contains: - Lists - List-Triggered Flow - Content Variables - AMPscript / Handlebars - Marketing Objects - CRM Personalization", "vidyardLink": "", "soLink": "Flow for Marketing - Summer '26 (262) Solution Overview", "pmmSlide": "", "customerValue": "", "persona": "B2B Marketer", "pmmLead": "", "cxLead": "", "pft": "Marketing on Core", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> B2B marketers on MC Next need to run simple batch email sends against CRM records, but the current approach requires Data Cloud segmentation \u2014 which introduces latency, identity resolution complexity, and a steep learning curve for MCAE migrants.<br><br><strong>What's New:</strong> List-Triggered Flows allow batch orchestration against the CRM List entity. Schedule and run batch sends directly from Marketing Lists without Data Cloud pipeline dependencies. Includes debug support for List Triggered Flows.<br><br><strong>How to Demo:</strong> Create a Marketing List \u2192 build a List-Triggered Flow \u2192 add email send with content variables and personalization \u2192 schedule the batch send. Show the debug tools for troubleshooting. Emphasize: 'The familiar batch send experience for MCAE customers, rebuilt on platform.'<br><br><strong>Customer Value:</strong> Dramatically reduces time-to-value for B2B customers. No Data Cloud prerequisite for simple batch sends. MCAE customers get a familiar workflow on the modern platform.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_segments.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"high-tech": "<strong>High-Tech Angle:</strong> For product-led growth companies with high-velocity marketing (weekly product updates, feature announcements, webinar invites), List-Based Orchestration means fast batch sends to targeted lists without the overhead of CDP segmentation."}, "demoUrl": "https://drive.google.com/file/d/13Xhr8rbXldUD4Ma7jkro944y0gsuOVSt/view?usp=drive_link", "soUrl": "https://docs.google.com/presentation/d/1rP8Mm5ePH4SfqYInhsg9huTeb-8ETzgT4wyjuFBFy38/edit?slide=id.g3d6cc16200a_0_1841"}, {"id": "f020", "theme": "2. B2B Revenue Support", "themeNumber": 2, "program": "Optimize MoC for B2B", "feature": "Marketing Lists in MoC", "pmOwner": "Cara Clanton Pope", "description": "Provide a simpler experience for marketers to create & manage a \u2018ready-to-engage list\u2019 of the audience (aka \u201cLists\u201d or \u201cMarketing Lists\u201d) to support simple batch\u2019n\u2019blast use cases, without any need of data pipeline or CDP related know-hows such as unifications and identity resolutions. Scope includes introducing 'List' as a new standard objects as part of MoC app and object lifecycle around it.", "goals": "Reduce adoption barriers for B2B customers, especially the MCAE cohort where marketing lists were second nature to the user base", "engOwner": "Emily Fitzgerald", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "PM Discretion for Distinct Demo of This Feature or Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "E2E Summer Demo Contains: - Lists - List-Triggered Flow - Content Variables - AMPscript / Handlebars - Marketing Objects - CRM Personalization", "vidyardLink": "", "soLink": "262 Actionable Lists for Marketing SO", "pmmSlide": "", "customerValue": "", "persona": "Marketing Manager", "pmmLead": "", "cxLead": "", "pft": "Marketing on Core", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> MCAE customers relied on Marketing Lists as a fundamental workflow \u2014 but MC Next requires Data Cloud segmentation for everything, which is overkill for simple 'send to this list' use cases and creates adoption friction.<br><br><strong>What's New:</strong> Marketing Lists are now a native standard object in Marketing on Core. Create, manage, and engage lists directly in the app without Data Cloud or identity resolution. Supports the full list lifecycle: create \u2192 populate \u2192 trigger flow \u2192 analyze.<br><br><strong>How to Demo:</strong> Navigate to Marketing Lists \u2192 create a new list \u2192 add members (manual, import, or criteria-based). Then trigger a flow from the list. Show the list management UI. Emphasize: 'This is the experience MCAE customers have been waiting for.'<br><br><strong>Customer Value:</strong> Removes the single biggest adoption barrier for MCAE customers. Lists work without CDP knowledge. A simpler, faster path to value for B2B teams.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_segments.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "demoUrl": "https://drive.google.com/file/d/13Xhr8rbXldUD4Ma7jkro944y0gsuOVSt/view?usp=drive_link", "soUrl": "https://docs.google.com/presentation/d/1W5_DUVNf5Js8ZoiUY1UAuQuGQoz2Jyn7ubiREX7grFE/edit?slide=id.g3d16249537f_0_0"}, {"id": "f021", "theme": "2. B2B Revenue Support", "themeNumber": 2, "program": "Sales + Marketing", "feature": "Account Discovery & Buying Group Agent", "pmOwner": "Lucie de Castrique", "description": "To evolve beyond single-contact qualification by delivering an intelligent assistive agent that transforms qualification from a static, one-time assessment into a dynamic, continuous process. The single most important outcome is to produce an account that is qualified for an opportunity, providing sales teams with a holistic view of engagement that will directly improve win rates on multi-threaded deals.", "goals": "To move beyond agentic single-lead nurturing to a more effective account-based or buyer group-based strategy, resulting in a faster and more predictable sales pipeline.", "engOwner": "Donald Gowens", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "Distinct Demo of This Feature", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "ADA - Demo.mp4", "vidyardLink": "", "soLink": "Account Discovery Agent - Solution Overview", "pmmSlide": "", "customerValue": "Admins enable the agent via the Agentforce Builder, and grant permission to ABM Marketers to access key actions: Summarize account engagement, who is most engaged, identify and find new/missing contacts.", "persona": "ABM Marketers", "pmmLead": "Megan Cohn", "cxLead": "Emily Bradley", "pft": "Marketing Einstein", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> B2B qualification is stuck in single-contact mode. Marketers qualify individual leads but can't see the full buying group or account-level engagement signals needed for multi-threaded enterprise deals.<br><br><strong>What's New:</strong> An Agentforce agent that evolves qualification from single-contact to account-based. It identifies buying groups, summarizes account engagement, finds missing contacts, and produces account-qualified opportunities for sales.<br><br><strong>How to Demo:</strong> Open Agentforce Builder \u2192 show the Account Discovery Agent configuration. Then demo the agent in action: 'Summarize engagement for Acme Corp' \u2192 agent shows engagement across contacts, identifies the buying group, flags missing decision-makers, and recommends moving to opportunity. Emphasize the shift from lead-based to account-based qualification.<br><br><strong>Customer Value:</strong> Transforms B2B qualification from reactive lead scoring to proactive account intelligence. Sales teams get multi-threaded deal opportunities with full buying group visibility. Directly improves win rates on enterprise deals.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_sales_alignment.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"high-tech": "<strong>High-Tech Angle:</strong> For SaaS companies selling to enterprises, the buying group typically includes a champion, economic buyer, technical evaluator, and procurement contact. This agent identifies all four and maps their engagement \u2014 giving SDRs the full picture before outreach.", "regulated": "<strong>Regulated Industries Angle:</strong> In institutional financial services, account qualification involves relationship managers, investment committees, and compliance officers. The agent maps engagement across all stakeholders in the buying group, helping wealth managers prioritize institutional prospects.", "cbs": "<strong>Consumer Business Services Angle:</strong> For B2B services companies (staffing, consulting, facilities management), buying groups span multiple departments. The agent reveals which procurement contacts, hiring managers, and C-suite sponsors are engaged \u2014 accelerating complex service deals."}, "demoUrl": "https://drive.google.com/file/d/1rCf2tk7dO2NGwUHwL1QMpiUn98ZPlLXE/view?usp=drive_link", "soUrl": "https://docs.google.com/presentation/d/12-9-kxoaqj9mlsxRMhumWfCi_GMkVvCCRUnIAUbLy_g/edit?slide=id.g3dca0498e92_0_3761"}, {"id": "f022", "theme": "3. Marketing Data Foundation", "themeNumber": 3, "program": "App Fundamentals", "feature": "Business Units Enhancements: Content Syndication", "pmOwner": "Robert Phillips", "description": "Ability to \"push\" a piece of content in one Business Unit to a CMS workspace in another Business Unit. After push, personalization refrencing BU specific data model is identified and flagged to be manually updated by end user. After personalization is updated to reference the new Business Unit's data model, content can be made available for use.", "goals": "improve the scalability and management of Business Units", "engOwner": "Prakhar Jain", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "PM Discretion for Distinct Demo of This Feature or Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "Content_Cloning_Demo.mp4", "vidyardLink": "", "soLink": "Marketing Cloud Advanced Business Units Content Cloning Solution Overview Guide (INTERNAL)", "pmmSlide": "", "customerValue": "Saves significant time by eliminating manual recreation of content, ensures strict brand consistency, and multiplies the ROI of high-performing content.", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Marketing on Core", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Enterprise customers with multiple Business Units (BUs) manually recreate content in each BU's workspace \u2014 duplicating effort, introducing brand inconsistencies, and wasting the ROI of high-performing content.<br><br><strong>What's New:</strong> Content Syndication lets you push content from one BU's CMS workspace to another. Personalization references are flagged for manual updating to the target BU's data model. Content is available for use once personalization is updated.<br><br><strong>How to Demo:</strong> Navigate to Content Builder in BU-A \u2192 select a high-performing email \u2192 click 'Syndicate to BU' \u2192 choose BU-B. Show the content appearing in BU-B's workspace with flagged personalizations. Walk through updating the personalizations. Emphasize: 'One piece of content, deployed across all your BUs.'<br><br><strong>Customer Value:</strong> Eliminates hours of manual content recreation. Ensures brand consistency across BUs. Multiplies the ROI of winning content across the enterprise.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_campaigns.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "demoUrl": "https://drive.google.com/file/d/1ALvYjGDyTIu_xnpN9dYhjVJQnHWhIqCK/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1cJFOi2jUAbOPjj2_8TBRLnsMEEqztypMIqd8vYmrFkI/edit?slide=id.g27237791d76_0_2117"}, {"id": "f023", "theme": "3. Marketing Data Foundation", "themeNumber": 3, "program": "App Fundamentals", "feature": "Business Units Enhancements: Increase Limit", "pmOwner": "", "description": "Increase limit on BUs from 50 to 150. Test performance and updated UI to accommodate higher number of rows.", "goals": "", "engOwner": "Prakhar Jain", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "PM Discretion for Distinct Demo of This Feature or Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "Screen Recording 2026-05-07 at 6.07.11\u202fPM.mov", "vidyardLink": "", "soLink": "n/a", "pmmSlide": "", "customerValue": "Allow customers to scale to match the numbver of divisions their business has.", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Marketing on Core", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Enterprise customers with more than 50 divisions hit the Business Unit limit, forcing workarounds that compromise their information architecture and marketing governance.<br><br><strong>What's New:</strong> The BU limit increases from 50 to 150, with performance-tested UI updates to accommodate the higher count. The BU management interface scales cleanly.<br><br><strong>How to Demo:</strong> Show the updated BU management page with the new limit badge. If applicable, show the performance \u2014 scrolling through 100+ BUs with no lag. Emphasize: 'Built and tested for enterprise scale.'<br><br><strong>Customer Value:</strong> Unblocks enterprise customers who need BU-per-division architecture. No more workarounds or compromised governance models.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_campaigns.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "demoUrl": "https://drive.google.com/file/d/1jxHOdILMFIrqSZiziUhD1sHWdCo13_fH/view?usp=sharing"}, {"id": "f024", "theme": "3. Marketing Data Foundation", "themeNumber": 3, "program": "App Fundamentals", "feature": "Business Units Enhancements: BU Lifecycle Management", "pmOwner": "", "description": "Add the ability to delete a Data Space (currently not possible when marketing is enabled because of the Business Unit relationship to a Data Space). Additoinaly, provide the abilty to inactivate a Business Unit (for deleting the Data Space, or for other business use cases).", "goals": "", "engOwner": "Prakhar Jain", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "PM Discretion for Distinct Demo of This Feature or Bundle Some Other Theme Features with this Demo", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "business-lifecycle-demo.mov", "vidyardLink": "", "soLink": "Marketing Cloud Advanced Business Units Lifecycle Management Solution Overview Guide (INTERNAL)", "pmmSlide": "", "customerValue": "Marketing teams can maintain a clean, clutter-free workspace/ information architecture without losing valuable historical performance data.", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Marketing on Core", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> When a Business Unit is no longer needed, you can't delete the associated Data Space (because of the BU dependency), and there's no way to deactivate a BU \u2014 leading to clutter, confusion, and wasted resources.<br><br><strong>What's New:</strong> BU Lifecycle Management adds the ability to inactivate Business Units and delete Data Spaces that have marketing enabled. Inactive BUs preserve historical data while removing them from active workflows.<br><br><strong>How to Demo:</strong> Navigate to BU management \u2192 select a BU \u2192 click 'Inactivate.' Show that historical data is preserved but the BU no longer appears in active selection lists. Then show deleting the orphaned Data Space. Emphasize: 'Clean architecture without losing history.'<br><br><strong>Customer Value:</strong> Marketing teams maintain clean, organized workspaces. Historical performance data is preserved for reporting. Reduces operational clutter and potential for sending errors.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_campaigns.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "demoUrl": "https://drive.google.com/file/d/1QhurDqSBmgCkLLy96LYs3_ZOHbJbD5G7/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/1cCtd5XTRh6LHZ-phhGDib-jpe2TkD7436bqtC3vSpgQ/edit?slide=id.g27237791d76_0_2117"}, {"id": "f025", "theme": "4. Transactional", "themeNumber": 4, "program": "Transactional for All Channels", "feature": "Multi-Channel Support Completeness", "pmOwner": "Karan Shetty", "description": "Deliver advanced transactional use cases beyond Critical Alerts  to other key high-priority channels: SMS, WhatsApp, and Mobile App. Validate against the Delta Airlines ticket receipt use case for Email and extending the same low-latency, dynamic personalization model launched in 260 for email", "goals": "Expand Channesl for transactional messaging.", "engOwner": "Anup Kamath", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "N/A", "considerations": "N/A", "demoLink": "N/A - The feature is simply additional channel support ( i.e SMS & WhatsApp) that has been added to an existing feature ( API triggered Transactional Messaging) that was launched in 260 for Email (Email Demo Link.)", "vidyardLink": "", "soLink": "https://docs.google.com/presentation/d/14B-yXLpLZmUxFFRpQi30V5hGGTv1BbDBxwgkYqozNew/edit?slide=id.g2d4921b147e_2_2768#slide=id.g2d4921b147e_2_2768", "pmmSlide": "", "customerValue": "Customers now get the option to Trigger Transactional Messages via an API for 2 additional channels  i.e SMS & WhatsApp in addition to the currently supported Email Channel", "persona": "Salesforce Admin, Marketing Manager", "pmmLead": "", "cxLead": "Nikhil Sulluru", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Transactional messaging (order confirmations, appointment reminders, security alerts) launched for email in release 260, but SMS and WhatsApp transactional use cases were unsupported \u2014 forcing customers to use third-party solutions for non-email alerts.<br><br><strong>What's New:</strong> API-triggered transactional messaging now supports SMS and WhatsApp in addition to email. Same low-latency, dynamic personalization model from the 260 email launch, extended to messaging channels.<br><br><strong>How to Demo:</strong> Show the API documentation for triggering a transactional SMS and WhatsApp message. Walk through the configuration in Unified Messaging \u2192 Transactional settings. If possible, trigger a test transactional SMS. Emphasize: 'One API, three channels \u2014 email, SMS, WhatsApp.'<br><br><strong>Customer Value:</strong> Unified transactional messaging across channels. Eliminates third-party dependencies for SMS/WhatsApp alerts. Same reliability and SLA expectations as the email transactional platform.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_data.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"regulated": "<strong>Regulated Industries Angle:</strong> Security alerts, fraud notifications, and appointment reminders via SMS and WhatsApp are critical for banking and healthcare. Transactional priority means these messages bypass marketing queues \u2014 ensuring time-sensitive alerts arrive instantly.", "retail-mfg": "<strong>Retail & Manufacturing Angle:</strong> Order confirmations via WhatsApp, shipping notifications via SMS, delivery alerts across channels \u2014 all from one API. Demo the Delta Airlines ticket receipt use case adapted for retail: 'Order shipped' via WhatsApp with personalized tracking link."}, "demoUrl": "https://drive.google.com/file/d/1Y3xB39dJTOTYK4qhkn7PU-siakUTgvtm/view?usp=sharing", "soUrl": "https://docs.google.com/presentation/d/14B-yXLpLZmUxFFRpQi30V5hGGTv1BbDBxwgkYqozNew/edit?slide=id.g2d4921b147e_2_2768"}, {"id": "f026", "theme": "4. Transactional", "themeNumber": 4, "program": "Transactional for All Channels", "feature": "Enterprise-Grade Performance & SLA Commitments", "pmOwner": "Karan Shetty", "description": "The primary objective of this initiative is to establish Marketing Cloud Next (MC Next) as the most reliable and trusted platform in the market for mission-critical transactional communications. We will achieve this by architecting the system to prioritize critical transactional traffic with zero contention and by formalizing industry-leading Service Level Agreement (SLA) commitments.", "goals": "Make progress with telemetry to provide observability of a future SLA's.", "engOwner": "Anup Kamath", "targetRelease": "262", "actualRelease": "", "demoType": "Apps&Ind Only", "coverageType": "N/A", "considerations": "N/A", "demoLink": "N/A", "vidyardLink": "", "soLink": "N/A", "pmmSlide": "", "customerValue": "", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Channels", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Mission-critical transactional communications (fraud alerts, password resets, transaction confirmations) must be delivered with guaranteed latency \u2014 but shared infrastructure creates contention between marketing batch sends and transactional messages.<br><br><strong>What's New:</strong> Architecture improvements to prioritize critical transactional traffic with zero contention. Telemetry and observability foundations for future SLA formalization. MC Next positions itself as the most reliable platform for mission-critical transactional communications.<br><br><strong>How to Demo:</strong> This is primarily an architectural/Apps & Industries demo. Show the telemetry dashboard (if available) demonstrating message delivery latency. Explain the zero-contention architecture. Emphasize: 'Transactional traffic gets priority \u2014 always.'<br><br><strong>Customer Value:</strong> Confidence that mission-critical messages will be delivered on time. Foundation for formal SLA commitments. Competitive differentiator against legacy ESPs without dedicated transactional infrastructure.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_data.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}}, {"id": "f027", "theme": "5. Modern Marketing", "themeNumber": 5, "program": "Agentic Marketing", "feature": "Answer Engine Optimization", "pmOwner": "Madhuri Jain", "description": "Create n AI Visibility Dashboard \u2014 a native Salesforce concept that helps brands: Tracks visibility: Measures AI visibility score, sentiment, brand presence across AI-generated responses Competitive insights: Benchmarks performance against peers. AI-powered guidance: Recommends content improvements \u2014 like FAQs \u2014 to close visibility gaps", "goals": "Brands are able to measure their AI visibility score and perform actions to improve it.", "engOwner": "Matt Trepina", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "N/A", "considerations": "Summer '26 release is a pilot. The ideal customer is just dipping their toe in AEO monitoring or wants to influence AEO's integration into Salesforce Marketing Cloud.", "demoLink": "Demo", "vidyardLink": "", "soLink": "Answer Engine Optimization Summer '26 Solution Overview", "pmmSlide": "", "customerValue": "", "persona": "Marketing Admin, Marketing Manager", "pmmLead": "", "cxLead": "Mary Anderson", "pft": "Marketing Einstein", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> As AI assistants (ChatGPT, Gemini, Perplexity) increasingly answer questions that previously drove web traffic, brands are invisible in AI-generated responses. There's no way to measure or improve how AI represents your brand.<br><br><strong>What's New:</strong> An AI Visibility Dashboard native to Salesforce that tracks your brand's AI visibility score, sentiment, and presence across AI-generated responses. Includes competitive benchmarking and AI-powered content recommendations (like FAQs) to close visibility gaps. Summer '26 is a pilot release.<br><br><strong>How to Demo:</strong> Open the Answer Engine Optimization dashboard \u2192 show the AI visibility score, brand mention tracking, and competitive comparison. Walk through the content recommendations. Emphasize: 'This is the SEO of the AI era \u2014 and we're the first to offer it natively.'<br><br><strong>Customer Value:</strong> First-mover advantage in AI-era brand visibility. Actionable insights to improve how AI represents your brand. Competitive intelligence on AI share-of-voice.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_einstein.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {"high-tech": "<strong>High-Tech Angle:</strong> For SaaS companies whose products are frequently compared in AI assistant responses ('What's the best CRM?'), AEO reveals how their brand performs vs. competitors in AI-generated recommendations. Demo the competitive benchmarking for a B2B software category.", "retail-mfg": "<strong>Retail & Manufacturing Angle:</strong> When consumers ask AI 'What's the best running shoe?' or 'Best organic dog food?', brand visibility in AI responses drives purchase consideration. AEO helps retail brands monitor and optimize their presence in these new discovery channels."}, "demoUrl": "https://drive.google.com/drive/folders/1-IqS_kEybrs6XwCxIHz1ND-zEt-3T3OZ", "soUrl": "https://docs.google.com/presentation/d/1hmyyWAu6bTwY6W8k1dzLPaAAlRZEaFdnZqFjdKaWDwc/edit?slide=id.g27237791d76_0_2106"}, {"id": "f028", "theme": "5. Modern Marketing", "themeNumber": 5, "program": "MCN Ease of Use", "feature": "Flow Edit History", "pmOwner": "Blake Markham", "description": "", "goals": "", "engOwner": "Nitika Aggarwal", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "Distinct Demo of This Feature", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "", "vidyardLink": "", "soLink": "https://org62.lightning.force.com/lightning/r/R_D_Program__c/a0ped0000023doTAAQ/view", "pmmSlide": "", "customerValue": "", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Marketing on Core", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> When multiple marketers collaborate on flows, there's no audit trail of who changed what and when. If a flow breaks, there's no way to identify the problematic edit or roll back to a previous state.<br><br><strong>What's New:</strong> Flow Edit History tracks all changes to marketing flows with timestamps, user attribution, and change details. Full audit trail of flow modifications.<br><br><strong>How to Demo:</strong> Open a marketing flow \u2192 navigate to Edit History. Show the timeline of changes: who modified the flow, what they changed, when. If available, show the comparison between versions. Emphasize the governance value: 'Every change tracked, every editor accountable.'<br><br><strong>Customer Value:</strong> Enterprise governance for marketing automation. Faster debugging when flows break. Compliance teams can audit marketing flow changes.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_campaigns.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "soUrl": "https://org62.lightning.force.com/lightning/r/R_D_Program__c/a0ped0000023doTAAQ/view"}, {"id": "f029", "theme": "5. Modern Marketing", "themeNumber": 5, "program": "MCN Ease of Use", "feature": "Guided Lead Capture", "pmOwner": "P.J. Nix", "description": "Make Publishing Forms much easier for the Starter Marketer (Starketer) by allowing for easy configuration of object creation and consent management.", "goals": "", "engOwner": "Shreyas Diwan", "targetRelease": "262", "actualRelease": "", "demoType": "Apps&Ind Only", "coverageType": "N/A", "considerations": "N/A", "demoLink": "", "vidyardLink": "", "soLink": "262 Solution Overview: Content Builder", "pmmSlide": "", "customerValue": "", "persona": "Marketing Manager", "pmmLead": "", "cxLead": "", "pft": "Marketing on Core", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Starter-tier marketers ('Starketers') struggle to set up lead capture forms because creating the right object records and managing consent requires Salesforce configuration knowledge they don't have.<br><br><strong>What's New:</strong> Guided Lead Capture simplifies form publishing with easy configuration of object creation and consent management. The setup wizard handles the Salesforce plumbing behind a marketer-friendly interface.<br><br><strong>How to Demo:</strong> Open Content Builder \u2192 start a new Form \u2192 walk through the Guided Lead Capture wizard. Show how it auto-creates the necessary object mapping and consent fields. Emphasize the simplicity: 'No Salesforce admin needed.'<br><br><strong>Customer Value:</strong> Dramatically lowers the bar for lead capture in MC Next. Starter-tier customers get productive faster. Reduces dependence on admins for basic marketing operations.", "helpArticleLink": "https://help.salesforce.com/s/articleView?id=release-notes.rn_mktg_campaigns.htm&language=en_US&release=262&type=5", "slideLink": "", "verticalVariants": {}, "soUrl": "https://docs.google.com/presentation/d/1wbJfe2llBJ8XF3Jtx1aF53acdCOGzkrHIRjBChh5P00/edit?slide=id.g3de204e12f9_4_0"}, {"id": "f030", "theme": "5. Modern Marketing", "themeNumber": 5, "program": "Personalized Content & Experiences", "feature": "Content Variants/In-App Translation", "pmOwner": "Sindhu Tiwari", "description": "Enable profile-driven, real-time delivery of multilingual Content Variants within a unified content editor interface for Marketing Cloud on Core. This provides a modern content framework that allows customers to manage global campaigns efficiently and unlocks crucial ISV extensibility for automated translation services.", "goals": "", "engOwner": "Sriti Kumar", "targetRelease": "262", "actualRelease": "", "demoType": "Customer-Facing Demo", "coverageType": "Distinct Demo of This Feature", "considerations": "Note value-prop; Consider showing brief example use case / how-to think about it; Intentional to quickly guide around any common issues or FAQ a customer might have; put yourself in the shoes of the given persona(s). Consider taking extra beats to connect dots/terms for customers instead of assuming they understand next-gen jargon", "demoLink": "Translations 262.mp4", "vidyardLink": "https://salesforce.vidyard.com/watch/mY34zMA3Gu6LqGaLp7J3eW", "soLink": "262 Solution Overview: Content Builder", "pmmSlide": "", "customerValue": "", "persona": "", "pmmLead": "", "cxLead": "", "pft": "Marketing on Core", "releaseStatus": "", "talkTrack": "<strong>Business Problem:</strong> Global marketing teams manage translations in spreadsheets or external tools, then manually recreate content in each language \u2014 a slow, error-prone process that can't scale for multi-market campaigns.<br><br><strong>What's New:</strong> Content Variants with in-app translation enable profile-driven, real-time delivery of multilingual content within a unified content editor. Supports ISV extensibility for automated translation services. Manage all language variants of a content asset in one place.<br><br><strong>How to Demo:</strong> Open Content Builder \u2192 create/edit an email \u2192 click 'Add Translation' \u2192 show the side-by-side editor with original and translated conten